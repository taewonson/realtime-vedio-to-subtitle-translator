# =========================
# Google 인증 (중요)
# =========================
# 서비스 계정 JSON 파일은 GCP_CREDENTIALS_FILE 경로에서 읽습니다.

# 라즈베리파이 LCD 네트워크 설정
# PC 앱이 자막 데이터를 보낼 라즈베리파이 IP입니다.
# 실제 라즈베리파이의 Wi-Fi 또는 LAN IP로 바꿔주세요.
SUBTITLE_PI_IP=192.168.35.165
SUBTITLE_PI_PORT=5005

# 라즈베리파이 LCD 앱이 재생/정지/탐색/언어 변경 명령을 보낼 PC IP입니다.
# 라즈베리파이에서 실행할 때는 실제 PC의 Wi-Fi 또는 LAN IP로 바꿔주세요.
SUBTITLE_PC_IP=192.168.55.131
SUBTITLE_PC_COMMAND_PORT=5006

# 라즈베리파이 LCD 화면 설정
SUBTITLE_LCD_GEOMETRY=800x480
SUBTITLE_LCD_FULLSCREEN=1