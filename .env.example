# Google Cloud 설정
GCP_PROJECT_ID=your-google-cloud-project-id
GCP_CREDENTIALS_FILE=credentials/google_service_account.json

# Speech-to-Text 설정
GCP_STT_LANGUAGE=en-US
GCP_STT_ALTERNATIVE_LANGUAGES=ko-KR
GCP_STT_CHUNK_SECONDS=50

# 번역 설정
GCP_TRANSLATE_LOCATION=global
GCP_TRANSLATE_BATCH_SIZE=100

# 라즈베리파이 LCD 네트워크 설정
# PC 앱이 자막 데이터를 보낼 라즈베리파이 IP입니다.
# 실제 라즈베리파이의 Wi-Fi 또는 LAN IP로 바꿔주세요.
SUBTITLE_PI_IP=127.0.0.1
SUBTITLE_PI_PORT=5005

# 라즈베리파이 LCD 앱이 재생/정지/탐색/언어 변경 명령을 보낼 PC IP입니다.
# 라즈베리파이에서 실행할 때는 실제 PC의 Wi-Fi 또는 LAN IP로 바꿔주세요.
SUBTITLE_PC_IP=127.0.0.1
SUBTITLE_PC_COMMAND_PORT=5006

# 라즈베리파이 LCD 화면 설정
SUBTITLE_LCD_GEOMETRY=1024x600
SUBTITLE_LCD_FULLSCREEN=1
